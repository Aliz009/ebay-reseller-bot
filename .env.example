# ===== eBay API (สมัครฟรีที่ https://developer.ebay.com/ → My Account → Application Keys) =====
# เอาค่า "Production" (ไม่ใช่ Sandbox) มาใส่
EBAY_CLIENT_ID=your-ebay-app-id-here
EBAY_CLIENT_SECRET=your-ebay-cert-id-here

# ===== Telegram =====
# 1) แชทกับ @BotFather ใน Telegram → /newbot → เอา token มาใส่
TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-here
# 2) แชทกับ @userinfobot เพื่อดู chat id ของคุณ (หรือ id ของกลุ่ม) แล้วเอามาใส่
TELEGRAM_CHAT_ID=your-chat-id-here
